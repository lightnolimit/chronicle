# CHRONICLE Agent Environment Variables

# EVM private key for x402 payments (must have 0x prefix)
# This key is used to pay Turbo for uploads
EVM_PRIVATE_KEY=0x...

# EVM address to receive payments from users
# This is where USDC payments will be sent
EVM_ADDRESS=0x...

# Network: base (mainnet) or base-sepolia (testnet)
NETWORK=base

# Optional: API server port (default: 3001)
# PORT=3001

# Optional: ARWEAVE_JWK for direct Arweave wallet operations
# ARWEAVE_JWK={"kty":"RSA",...}

# Optional: Turbo token preference (default: ethereum)
# TURBO_TOKEN=ethereum

# Chutes API key for AI generation (only used on mainnet)
# Get your API key from https://chutes.ai
CHUTES_API_KEY=chures_...

# =============================================================================
# Virtuals Protocol ACP Configuration
# =============================================================================

# Enable ACP runtime (set to 'true' to enable)
# ACP_ENABLED=true

# Whitelisted ACP dev wallet private key used to sign ACP memos
# Falls back to EVM_PRIVATE_KEY if omitted, but set this explicitly in production
# ACP_WHITELISTED_WALLET_PRIVATE_KEY=0x...

# ACP Session Entity Key ID (from Virtuals Service Registry)
# Get this from https://app.virtuals.io/acp/join after registering your agent
# ACP_SESSION_KEY_ID=12345

# ACP Agent Wallet Address (your agent's smart wallet address)
# Get this from the Virtuals Service Registry after creating your agent
# ACP_AGENT_WALLET=0x...

# ACP network (defaults to NETWORK)
# ACP_NETWORK=base

# Optional: Custom RPC URL for ACP (avoids rate limits)
# ACP_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-api-key

# Optional ACP queue controls
# ACP_QUEUE_DEPTH=10
# ACP_CONCURRENCY_STORAGE=2
# ACP_CONCURRENCY_TEXT=2
# ACP_CONCURRENCY_IMAGE=1
# ACP_CONCURRENCY_VIDEO=1

# Optional ACP offering flags
# ACP_ENABLE_IMAGE_OFFERING=false
# ACP_ENABLE_VIDEO_OFFERING=false
