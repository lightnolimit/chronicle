{
  "name": "agent",
  "version": "1.0.0",
  "description": "CHRONICLE - x402 Storage Agent for Virtuals Protocol ACP",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:api": "node dist/src/bin/api.js",
    "start:acp": "node dist/src/bin/acp-seller.js",
    "dev": "tsx src/index.ts",
    "dev:api": "tsx src/bin/api.ts",
    "dev:acp": "tsx src/bin/acp-seller.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "0.0.13",
    "@ardrive/turbo-sdk": "^1.41.0",
    "@payai/facilitator": "^2.2.4",
    "@virtuals-protocol/acp-node": "^0.3.0-beta.37",
    "@x402/axios": "^2.4.0",
    "@x402/evm": "^2.4.0",
    "@x402/express": "^2.4.0",
    "@x402/fetch": "^2.4.0",
    "ai": "^4.0.0",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "viem": "^2.21.35"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
